generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TenantRole {
  ADMIN
  MANAGER
  AUDITOR
  VIEWER
  MEMBER
}

enum AuditStatus {
  DRAFT
  SUBMITTED
}

enum CorrectiveActionStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model Tenant {
  id        String         @id @default(uuid()) @db.Uuid
  name      String
  logoUrl   String?
  slug      String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  categories Category[]
  templates  FormTemplate[]
  auditLogs  AuditLog[]
  correctiveActions CorrectiveAction[]
  members    TenantMember[]
  staffPins  TenantStaffPin[]
  activities ActivityLog[]
}

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String?  @db.Uuid
  userId     String   @db.Uuid
  action     String
  entityType String
  entityId   String?
  details    Json?    @db.JsonB
  createdAt  DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model TenantStaffPin {
  tenantId  String   @db.Uuid @map("tenant_id")
  userId    String   @db.Uuid @map("user_id")
  email     String
  fullName  String   @map("full_name")
  pinHash   String   @map("pin_hash")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, userId])
  @@index([userId])
  @@map("tenant_staff_pin")
}

model TenantMember {
  id        String     @id @default(uuid()) @db.Uuid
  tenantId  String     @db.Uuid
  userId    String     @db.Uuid
  role      TenantRole @default(MEMBER)
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
}

model Category {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @db.Uuid
  name      String
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templates FormTemplate[]

  @@unique([tenantId, name])
}

model FormTemplate {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  categoryId String?   @db.Uuid
  title      String
  isStandard Boolean   @default(false)
  schema     Json      @db.JsonB
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  auditLogs AuditLog[]

  @@index([tenantId])
  @@index([categoryId])
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  templateId String      @db.Uuid
  tenantId   String      @db.Uuid
  status     AuditStatus @default(SUBMITTED)
  payload    Json        @db.JsonB
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  submittedAt DateTime?

  template FormTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([templateId])
}

model CorrectiveAction {
  id          String                 @id @default(uuid()) @db.Uuid
  tenantId    String                 @db.Uuid
  sourceType  String?
  sourceId    String?
  title       String
  description String
  ownerName   String
  ownerEmail  String?
  dueDate     DateTime?
  status      CorrectiveActionStatus @default(OPEN)
  evidence    Json?                  @db.JsonB
  closedAt    DateTime?
  archivedAt  DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, sourceType, sourceId])
}

model CategorySuggestion {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TemplateLibrary {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  schema    Json     @db.JsonB
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
}
